<?xml version="1.0"?>
<!--
  Headless variant of odometry.launch for batch evaluation (no rviz, no GUI).

  The odometry_node reads the bag itself (bag_path), processes to completion in
  RunBag(), writes the trajectory + loop_log in SaveOdometry(), then returns 0.
  required="true" makes roslaunch tear down its auto-started roscore and exit as
  soon as the node returns, so a container `roslaunch ... ` call terminates on
  its own when the sequence is done.
-->
<launch>
  <arg name="config_path"   default="/config/ct_odometry_viral.yaml" />
  <arg name="bag_path"      default="" />
  <arg name="pasue_time"    default="-1" />
  <arg name="verbose"       default="false" />
  <arg name="launch_prefix" default="" />  <!-- optional debug wrapper, e.g. a gdb batch prefix -->

  <node pkg="cocolic" type="odometry_node" name="$(anon odometry_node)"
        output="screen" required="true" launch-prefix="$(arg launch_prefix)">
    <param name="project_path" type="string" value="$(find cocolic)" />
    <param name="config_path"  type="string" value="$(find cocolic)$(arg config_path)" />
    <param name="bag_path"     type="string" value="$(arg bag_path)" />
    <param name="pasue_time"   type="double" value="$(arg pasue_time)" />
    <param name="verbose"      type="bool"   value="$(arg verbose)" />
  </node>
</launch>
